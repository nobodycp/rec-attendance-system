# === قاعدة البيانات (Coolify) ===
# الطريقة الموصى بها: رابط واحد من Coolify
# DATABASE_URL=mysql://user:password@mysql-service:3306/default

# الطريقة البديلة: متغيرات منفصلة
DB_DRIVER=mysql
DB_HOST=mysql-service
DB_PORT=3306
DB_NAME=rec_attendance
DB_USER=rec
DB_PASS=change_me_strong_password

# === التطبيق ===
APP_NAME=جمعية مركز الإرشاد التربوي REC
APP_URL=https://attendance.example.com
APP_BASE_PATH=
APP_TIMEZONE=Asia/Riyadh
APP_DEBUG=false

# فعّل مؤقتاً لإنشاء حساب المسؤول الأول عبر /setup.php
SETUP_ENABLED=true
